# Environment Variables Template
# Copy this file to .env.local and fill in the values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-pub-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@yourdomain.com

#Google Maps Api 
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=WVWPVc

# DHL Shipping Integration (Optional - Fallback if not configured in Admin Settings)
# For multi-tenant templates, configure these in Admin > Settings > Shipping instead
# These ENV variables serve as fallback for development or single-store deployments
DHL_API_KEY=your-dhl-api-key-here
DHL_API_SECRET=your-dhl-api-secret-here
DHL_ACCOUNT_NUMBER=your-dhl-account-number-here
DHL_TEST_MODE=true

# Warehouse/Store Address (Optional - Fallback for shipper information)
WAREHOUSE_NAME=Your Store Name
WAREHOUSE_ADDRESS=123 Warehouse Street
WAREHOUSE_CITY=New York
WAREHOUSE_STATE=NY
WAREHOUSE_ZIP=10001
WAREHOUSE_COUNTRY=US
WAREHOUSE_PHONE=+1-555-0000

# FedEx Shipping Integration (Optional)
FEDEX_API_KEY=your-fedex-api-key-here
FEDEX_API_SECRET=your-fedex-api-secret-here
FEDEX_ACCOUNT_NUMBER=your-fedex-account-number-here
FEDEX_TEST_MODE=true

# UPS Shipping Integration (Optional)
UPS_API_KEY=your-ups-api-key-here
UPS_API_SECRET=your-ups-api-secret-here
UPS_ACCOUNT_NUMBER=your-ups-account-number-here
UPS_TEST_MODE=true
